# .env.production.example

# --- CORE SETTINGS ---
NODE_ENV=production
PORT=8080

# --- DATABASE & CACHE ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/dailypick?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
REDIS_URL=rediss://default:<password>@<railway-redis-url>:6379

# --- SECURITY & AUTH ---
# Explicitly bound to Vercel domains
ALLOWED_ORIGINS=https://supermarket-frontend.vercel.app,https://dailypick-admin.vercel.app
EXTERNAL_API_KEY=your_secure_webhook_key
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
COOKIE_SECRET=your_secure_random_cookie_secret_minimum_32_chars

# --- LIMITS (Enterprise Worker Guardrails) ---
BODY_LIMIT=1048576
MAX_EVENT_LOOP_DELAY=1000
MAX_HEAP_BYTES=1000000000

# --- EXTERNAL SERVICES ---
CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud_name>
CALLMEBOT_API_KEY=your_callmebot_key
WA_PHONE_NUMBER=+919999999999

# --- AI ---
GEMINI_API_KEY=your_google_gemini_key
