# .env.production.example

# ==========================================
# CORE SYSTEM CONFIGURATION
# ==========================================
NODE_ENV=production
PORT=8080
TZ=Asia/Kolkata

# NOTE: Replace this with your actual Railway MongoDB connection string
MONGO_URI=mongodb+srv://dummy_user:dummy_password@cluster0.mongodb.net/dailypick?retryWrites=true&w=majority

# NOTE: Replace this with your actual Railway Redis connection string
REDIS_URL=redis://default:dummy_password@redis-container.railway.app:6379

# ==========================================
# SECURITY & AUTHENTICATION (DUMMY KEYS)
# ==========================================
# Generate real keys later using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...DUMMY_KEY...=\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBI...DUMMY_KEY...=\n-----END PUBLIC KEY-----"

# Define your 4 specific Vercel project URLs here to lock down the backend
FRONTEND_URLS=https://dailypick-consumer.vercel.app,https://dailypick-admin.vercel.app,https://dailypick-hq.vercel.app,https://dailypick-rider.vercel.app

SYSTEM_API_KEY=DP_TEST_SYS_998877

# ==========================================
# PAYMENT & EXTERNAL SERVICES (DUMMY KEYS)
# ==========================================
# The frontend will dynamically fetch this. Leave as test until launch.
RAZORPAY_KEY=rzp_test_dummykey
RAZORPAY_SECRET=dummy_secret_do_not_use

# Cloudinary (Images)
CLOUDINARY_URL=cloudinary://dummy_api_key:dummy_secret@dummy_cloud_name

# Firebase Admin SDK (Auth)
FIREBASE_PROJECT_ID=dummy-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-dummy@dummy-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nDummyKey\n-----END PRIVATE KEY-----"

# ============================================================================
# --- NEW: PHASE 10 B2B2C OMNICHANNEL SECRETS (APPEND TO BOTTOM) ---
# ============================================================================

# 1. Firebase Cloud Messaging (FCM) - For waking up sleeping Rider/Customer Apps
FCM_PROJECT_ID="your-firebase-project-id"
FCM_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com"
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nFirebase\nPrivate\nKey\nHere\n-----END PRIVATE KEY-----\n"

# 2. Razorpay Split & Webhooks (For Omni-Cart Financial Routing)
RAZORPAY_KEY_ID="rzp_live_your_actual_key_here"
RAZORPAY_KEY_SECRET="your_razorpay_secret_here"
RAZORPAY_WEBHOOK_SECRET="your_secure_webhook_passphrase"

# 3. Railway Background Worker Constraints
ENABLE_WORKER_POLLING="true"
ENABLE_LOGISTICS_AUTOMATION="true"

# 4. Enterprise ERP Sync Defaults
DEFAULT_ERP_POLLING_INTERVAL_MS="1800000" # 30 minutes
